# ===========================================================================
# Server Configuration
# ===========================================================================
# The network port the HTTP server binds to (default: 1337)
PORT=1337

# The absolute public URL of your deployed addon (e.g., https://yourdomain.com)
# This is critical for generating stream resolution proxy links (/resolve).
ADDON_BASE_URL=http://localhost:1337

# ===========================================================================
# Logger Configuration
# ===========================================================================
# Log level: "error", "warn", "info", "debug", or "trace" (default: info)
EASYNEWS_LOG_LEVEL=info

# Deduplicate repeating debug log patterns dynamically to keep outputs clean
# Options: "true" or "false" (default: true)
EASYNEWS_SUMMARIZE_LOGS=true

# ===========================================================================
# API Metadata Integration Options
# ===========================================================================
# Optional TMDB (The Movie Database) API Key.
# If provided, the addon translates search queries and matches localized/alternative names.
TMDB_API_KEY=

# ===========================================================================
# Performance & API Cache Throttling
# ===========================================================================
# Bounded limit for total raw matching search results across pagination pages (default: 500)
TOTAL_MAX_RESULTS=500

# Bounded limit of successive Solr pages parsed per request (default: 10)
MAX_PAGES=10

# Bounded limit of files requested from Easynews in a single page (default: 250)
MAX_RESULTS_PER_PAGE=250

# Global advanced search API response cache duration in hours (default: 24)
CACHE_TTL=24

# Total cache capacity before the oldest entries are pruned (default: 1000)
MAX_CACHE_ENTRIES=1000

# Number of search queries resolved concurrently when fanning out (default: 5)
SEARCH_CONCURRENCY=5

# ===========================================================================
# Secure Resolving Proxy Options
# ===========================================================================
# Resolved geography-aware CDN URL cache duration in seconds (default: 300)
RESOLVE_CACHE_TTL_SECONDS=300

# Timeout in milliseconds for retrieving CDN redirect targets (default: 20000)
RESOLVE_TIMEOUT_MS=20000

# Legacy mode: Embed credentials directly in play URLs instead of proxying them (default: false)
# WARNING: Enabling this will expose your Easynews password in plaintext streams.
ALLOW_INSECURE_CREDENTIAL_URLS=false
